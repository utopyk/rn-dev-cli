{
  "name": "rn-dev-cli",
  "version": "0.1.0",
  "description": "React Native developer CLI with TUI, profile system, and metro manager",
  "type": "module",
  "bin": {
    "rn-dev": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "dev:renderer": "cd renderer && npx vite",
    "dev:electron": "electron electron/launcher.cjs",
    "dev:gui": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build": "bun run build.ts",
    "build:compile": "bun run build.ts compile",
    "build:renderer": "cd renderer && npx vite build",
    "build:electron": "npx electron-builder",
    "test": "bun test",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "cli",
    "tui",
    "developer-tools",
    "metro"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "figures": "^6.1.0",
    "fuse.js": "^7.1.0",
    "gradient-string": "^3.0.0",
    "log-symbols": "^7.0.1",
    "react": "^19.2.4",
    "semver": "^7.7.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
