    "fullscreen-ink": "^0.1.0",
    "fuse.js": "^7.1.0",
    "ink": "^6.8.0",
    "ink-multi-select": "^2.0.0",
    "ink-scroll-view": "^0.3.6",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
