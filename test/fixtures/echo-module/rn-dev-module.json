{
  "id": "echo",
  "version": "0.1.0",
  "hostRange": ">=0.1.0",
  "scope": "global",
  "contributes": {
    "mcp": {
      "tools": [
        {
          "name": "echo__ping",
          "description": "Echo fixture ping tool.",
          "inputSchema": { "type": "object" },
          "readOnlyHint": true
        }
      ]
    },
    "config": {
      "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "greeting": { "type": "string", "minLength": 1 },
          "loud": { "type": "boolean" }
        }
      }
    }
  },
  "permissions": [],
  "activationEvents": ["onStartup"]
}
